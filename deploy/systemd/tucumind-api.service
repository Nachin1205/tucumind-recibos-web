[Unit]
Description=Tucumind Recibos API
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/srv/tucumind-recibos-web/apps/api
EnvironmentFile=/srv/tucumind-recibos-web/apps/api/.env.production
ExecStart=/srv/tucumind-recibos-web/apps/api/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --proxy-headers --forwarded-allow-ips=127.0.0.1
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
