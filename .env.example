# API Configuration
PORT=8000
ENVIRONMENT=development

# Database Settings
# Production recommendation: use DATABASE_URL from your managed/external Postgres.
# If DATABASE_URL is defined, DB_* values are ignored.
# Example:
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tucumind_recibos
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=0
DB_POOL_RECYCLE=300

# Auth MVP
# To generate a hash for a password (e.g. 'admin123'), you can use bcrypt.
# Example: 
# import bcrypt; print(bcrypt.hashpw(b"admin123", bcrypt.gensalt()).decode())
# Output: $2b$12$Nq...
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=$2b$12$V.oZ8sB6Kz8B6hJ5QeZb6OeJ19m9FItkXq9JgEq9/8A8.A8w4X61O # Hash for "admin123"

# JWT configuration
SECRET_KEY=super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=480 # 8 hours
